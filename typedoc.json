{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [],
  "out": "./docs",
  "plugin": [
    "typedoc-plugin-markdown"
  ],
  "excludePrivate": true,
  "excludeProtected": true,
  "readme": "none",
  "skipErrorChecking": true,
  "hidePageHeader": true,
  "projectDocuments": [
    "documents/*.md",
    "documents/memory/*.md",
    "documents/tools/*.md"
  ],
  "hideBreadcrumbs": true,
  "gitRevision": "main"
}